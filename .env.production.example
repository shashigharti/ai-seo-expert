# Production .env for docker-compose.prod.yml - copy to `.env` in this same
# directory (repo root) on the ECS instance and fill in real values.
# Never commit the real .env (already gitignored).

# Required - docker-compose.prod.yml refuses to start without these.
POSTGRES_PASSWORD=
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Set to how the app is actually reached, e.g. http://<ecs-public-ip>:8000
# or https://your-domain.example. Frontend and API are served from the same
# origin in production (FastAPI serves the built React app - see
# docs/frontend-architecture.md §2), so this mainly matters if anything
# calls the API cross-origin.
ALLOWED_ORIGINS=["http://your-ecs-public-ip:8000"]

# Real Qwen Cloud key - see docs/deployment.md. Without it the app runs but
# every agent call fails with QwenClientConfigurationError. DashScope's two
# regions have non-interchangeable keys (mainland vs international console)
# - a key from one gets a real 401 invalid_api_key against the other's
# endpoint, so QWEN_BASE_URL must match where this key was actually issued:
# mainland:      https://dashscope.aliyuncs.com/compatible-mode/v1
# international: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Which real Qwen model backs each model_policies tier in
# backend/app/config/agents.yaml, by that tier's `thinking` flag - basic
# for thinking: false, reasoning for thinking: true.
QWEN_MODEL_BASIC=qwen-plus
QWEN_MODEL_REASONING=qwen-max

# Personal access token with repo write access, for opening fix PRs.
GITHUB_TOKEN=

# "local" writes artifacts to a volume on the ECS instance itself - no
# Alibaba Cloud OSS bucket needed, keeping this deployment at zero
# additional cost beyond the ECS instance. Switch to "oss" (and fill in the
# OSS_* vars below) only if you want off-instance artifact storage.
ARTIFACT_STORE_BACKEND=local
ARTIFACT_STORE_LOCAL_PATH=./data/artifacts
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

RATE_LIMIT_PER_MINUTE=60

DATABASE_URL=postgresql+asyncpg://aiseo:aiseo@localhost:5432/aiseo
ALLOWED_ORIGINS=["http://localhost:5173"]

SECRET_KEY=replace-with-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# DashScope has two separate regions with non-interchangeable API keys -
# an International-console key gets a real 401 invalid_api_key against the
# mainland endpoint and vice versa. Match this to where your key was issued:
# mainland China:  https://dashscope.aliyuncs.com/compatible-mode/v1
# international:   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Which real Qwen model backs each model_policies tier in
# app/config/agents.yaml, by that tier's `thinking` flag - basic for
# thinking: false, reasoning for thinking: true. Change here rather than
# editing agents.yaml if you want to swap models per-deployment (e.g. one
# model's quota runs out).
QWEN_MODEL_BASIC=qwen-plus
QWEN_MODEL_REASONING=qwen-max

GITHUB_TOKEN=

ARTIFACT_STORE_BACKEND=local
ARTIFACT_STORE_LOCAL_PATH=./data/artifacts
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

RATE_LIMIT_PER_MINUTE=60
